# Data directory on the host that persists the WhatsApp session and agent configs
CLAWDBOT_DATA_DIR=/opt/clawdbot/data

# Port the gateway listens on (host port, container always uses 19000)
GATEWAY_PORT=19000

# Memory limit for the container
MEMORY_LIMIT=4G

# AI model API keys (passed into the container for coding agents / tools)
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here
GEMINI_API_KEY=your_gemini_key_here

# GitHub token for gh CLI inside the container (optional)
GITHUB_TOKEN=your_github_token_here

# Any additional env vars your tools or agents need
# CUSTOM_VAR=value
