# ──────────────────────────────────────────────────────────────────────
# moto configuration
# Copy to `.env` and fill in. NEVER commit `.env`.
# ──────────────────────────────────────────────────────────────────────

# ── Identity ────────────────────────────────────────────────────────
# Your Mac user. Used for SSHFS mounts on the server (mac:/Users/$MAC_USER).
MAC_USER=yourname

# ── Server ──────────────────────────────────────────────────────────
# Public IP or hostname of your Linux box.
AX41_HOST=1.2.3.4
AX41_USER=root
AX41_SSH_KEY=~/.ssh/id_ed25519

# Port on the server that forwards back to your Mac's sshd (reverse tunnel).
# The Mac's launchd job runs: ssh -N -R $MAC_REVERSE_PORT:localhost:22 ax41
MAC_REVERSE_PORT=2222

# ── Claude / Codex / opencode ───────────────────────────────────────
# Optional: keys exported into tmux sessions (server-side).
# Leave blank if you rely on Claude Code's own auth.
GOOGLE_GENERATIVE_AI_API_KEY=
OPENROUTER_API_KEY=
DEEPINFRA_API_KEY=

# ── Cloudflare tunnel (optional — public hostnames for your dev servers) ──
# Get a token from: https://one.dash.cloudflare.com → Zero Trust → Networks → Tunnels
CLOUDFLARE_TUNNEL_TOKEN=

# ── Residential proxy (optional) ────────────────────────────────────
# Provider-agnostic. Examples:
#   Bright Data:  http://USER-country-us:PASS@brd.superproxy.io:22225
#   Smartproxy:   http://USER:PASS@gate.smartproxy.com:7000
#   Oxylabs:      http://customer-USER-cc-us:PASS@pr.oxylabs.io:7777
#   Generic:      socks5://USER:PASS@host:1080
# Leave blank to disable residential routing (agents will use the server's IP).
PROXY_URL=

# Which container services should egress through the proxy? Comma-separated.
# Options: runtime-api, dev-sandbox, authenticated-chrome
PROXY_APPLIES_TO=authenticated-chrome,runtime-api

# ── Cleanup thresholds ──────────────────────────────────────────────
# node_modules untouched for this many days will be deleted nightly.
NODE_MODULES_GC_DAYS=14
# next-server processes using more than this % CPU will be killed if orphaned.
NEXT_CPU_THRESHOLD=50
# orphan chrome processes running longer than this (hours) will be killed.
CHROME_MAX_AGE_HOURS=2
