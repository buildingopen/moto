# Gmail / IMAP multi-account configuration
# Copy to .env and fill in your values.
# chmod 600 .env
# Never commit .env to version control.

# Account 1
IMAP_LABEL_1=personal
IMAP_USER_1=you@gmail.com
IMAP_PASS_1=xxxx xxxx xxxx xxxx
IMAP_SERVER_1=imap.gmail.com

# Account 2
IMAP_LABEL_2=work
IMAP_USER_2=you@yourcompany.com
IMAP_PASS_2=xxxx xxxx xxxx xxxx
IMAP_SERVER_2=imap.gmail.com

# Account 3 (uncomment and fill as needed)
# IMAP_LABEL_3=clients
# IMAP_USER_3=clients@yourcompany.com
# IMAP_PASS_3=xxxx xxxx xxxx xxxx
# IMAP_SERVER_3=imap.gmail.com

# Account 4 - Yahoo example
# IMAP_LABEL_4=yahoo
# IMAP_USER_4=you@yahoo.com
# IMAP_PASS_4=xxxx xxxx xxxx xxxx
# IMAP_SERVER_4=imap.mail.yahoo.com

# Add more accounts by incrementing the number.
# The script reads all IMAP_LABEL_N groups it finds.
